# ICE Data Workbench v3 — environment template
# Copy to `.env` at repo root and fill in. Backend reads via pydantic-settings.

# ---- Core ----
# DATA_ROOT defaults to the repo root (auto-resolved). Leave commented for
# portability across machines.
# DATA_ROOT=
ICE_SECRET_KEY=change-me-please-32-bytes-min
ICE_ACCESS_TOKEN_TTL_MIN=60
ICE_REFRESH_TOKEN_TTL_DAYS=14
ICE_CORS_ORIGINS=http://localhost:5173

# ---- LLM gateway (preferred, OpenAI-compatible) ----
# Mify model gateway. Empty -> falls back to ANTHROPIC_API_KEY below.
MIFY_GATEWAY_BASE_URL=http://model.mify.ai.srv/v1/
MIFY_GATEWAY_API_KEY=
MIFY_DEFAULT_MODEL=ppio/pa/claude-opus-4-7

# ---- LLM legacy (Anthropic native SDK fallback) ----
# Only used when MIFY_GATEWAY_* missing. Empty -> /ws returns LLM_KEY_MISSING.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_BASE_URL=

# ---- Feishu OAuth ----
# Standard: https://open.feishu.cn/app  /  Xiaomi internal: see internal wiki
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_HOST=https://open.feishu.cn
FEISHU_REDIRECT_URI=http://localhost:5173/auth/feishu/callback

# ---- Kyuubi (Xiaomi internal SQL gateway) ----
# These 5 fields are the per-call defaults so kyuubi_query doesn't need to
# re-prompt for region/workspace each turn.
KYUUBI_REGION=chnbj
KYUUBI_WORKSPACE=
KYUUBI_CATALOG=iceberg_zjyprc_hadoop
KYUUBI_ENGINE=presto
KYUUBI_TOKEN=
# Backend shells out to the bundled `kyuubi` CLI; install on the deploy host:
#   pipx install xiaomi-kyuubi-cli   (or pip install --user xiaomi-kyuubi-cli)
# Without the binary on PATH, kyuubi_query returns KYUUBI_NOT_CONFIGURED.
# Legacy JDBC fallback (currently unused).
KYUUBI_HOST=
KYUUBI_PORT=10009
KYUUBI_USER=
KYUUBI_PASSWORD=

# ---- Bootstrap admin (super_admin) ----
ICE_BOOTSTRAP_ADMIN_EMAIL=admin
ICE_BOOTSTRAP_ADMIN_PASSWORD=admin123
ICE_BOOTSTRAP_ADMIN_NAME=系统管理员

# ---- 米盾 / Aegis (production auth) ----
# When enabled, every request must carry X-Proxy-UserDetail injected by the
# Aegis security proxy (dun.mi.com). JWT/password login is retired.
#
# AEGIS_PUBLIC_KEY: from the Aegis admin console ("安全代理公钥") — PEM or
# raw base64 DER. Rotations are supported: comma-separate multiple keys.
AEGIS_ENABLED=true
AEGIS_PUBLIC_KEY=
# Emails that should get super_admin role (comma-separated).
AEGIS_ADMIN_EMAILS=
# LOCAL DEV ONLY — setting this disables verification and pretends this user
# is logged in. MUST be empty in staging / prod.
AEGIS_DEV_BYPASS_EMAIL=
